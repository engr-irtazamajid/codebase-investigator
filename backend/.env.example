# ── Primary LLM provider (Gemini) ─────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Fallback LLM provider (OpenRouter) ────────────────────────────────────────
# Used automatically when Gemini key is absent OR quota is exceeded.
# Get your key at: https://openrouter.ai/keys
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=google/gemini-2.0-flash-lite   # any model slug from openrouter.ai/models

# ── Optional overrides (defaults shown) ───────────────────────────────────────
# MODEL_NAME=gemini-2.0-flash-lite
# EMBEDDING_MODEL=models/gemini-embedding-001
# MAX_RETRIEVAL_CHUNKS=8
# CHUNK_SIZE=60
# CHUNK_OVERLAP=15
# MAX_FILE_SIZE_KB=500
# MAX_CHUNKS_PER_REPO=1500
# CORS_ORIGINS=["http://localhost:3000"]
